{
  "name": "xiv-bars",
  "version": "2.2.0",
  "description": "The source code for XIVBARS, the Final Fantasy XIV Cross Hotbar (XHB) Planning Tool.",
  "private": true,
  "license": "GPL-3.0",
  "homepage": "https://www.xivbars.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bdejesus/xiv-bars.git"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "next start -p $PORT",
    "dev": "next dev",
    "build": "next build",
    "build:data": "node ./scripts/build_data.mjs",
    "lint": "eslint ./ --fix; stylelint './**/**/*.{css,scss,sass}' --fix",
    "lint:js": "eslint ./",
    "lint:css": "stylelint './**/**/*.{css,scss,sass}'",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:reset": "npx prisma migrate reset",
    "heroku-prebuild": "npx prisma migrate deploy",
    "postinstall": "prisma generate",
    "test": "jest --watch --silent false"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/nextjs": "^10.57.0",
    "ansi-colors": "^4.1.3",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.4.2",
    "fast-html-parser": "^1.0.1",
    "i18next": "^26.3.1",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "next-i18next": "^16.0.7",
    "pg": "^8.13.3",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-i18next": "^17.0.8",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "sass": "^1.101.0",
    "sitemap": "^9.0.1",
    "ssl-express-www": "^3.2.1",
    "vanilla-cookieconsent": "^3.0.1",
    "webpack": "^5.107.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/fast-html-parser": "^1.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.0",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-mock-extended": "^4.0.1",
    "json-loader": "^0.5.7",
    "node-mocks-http": "^1.13.0",
    "postcss": "^8.5.15",
    "postcss-scss": "^4.0.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
